# Caches
__pycache__/
*.pyc
.pytest_cache/

# Runtime state files
*.json
insta_watcher_state.json
instagram_seen.json
seen_messages.json

# Secrets
.env
.env.*
cookies_backup.json

# Session & browser data (regenerated on first login)
golden_tier_external_world/session/
session/*
!session/.gitkeep

# Runtime vault (SQLite databases)
golden_tier_external_world/vault/
vault/*
!vault/.gitkeep

# Logs (regenerated at runtime)
Logs/*
!Logs/.gitkeep

# Plan files (generated at runtime)
Plan/*
!Plan/.gitkeep

# Pipeline folders (empty at start, populated at runtime)
Done/*
!Done/.gitkeep
Approved/*
!Approved/.gitkeep
Pending_Approval/*
!Pending_Approval/.gitkeep
